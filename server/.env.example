# Database — same connection vars as clubsteward (see ../clubsteward/admin/.env.example).
# Copy ../clubsteward/admin/.env into server/.env, then set DB_SCHEMA=teamtask_hub, PORT=3001, JWT_SECRET.
DB_HOST=d16057.usc1.stableserver.net
DB_PORT=5432
DB_DATABASE=kindredv_kindred
DB_USER=kindredv_master
DB_PASSWORD=your_password_here
DB_SCHEMA=teamtask_hub
# TLS is on by default (same shared DB as clubsteward). For local Postgres without SSL: DB_SSL=false

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars

# Optional: Square Team API (fetch active users)
SQUARE_ACCESS_TOKEN=
SQUARE_ENV=production

# Optional: Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional: Email for password reset (SMTP)
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_SECURE=false
# MAIL_USER=
# MAIL_PASS=
# MAIL_FROM=noreply@yourdomain.com

# Base URL for reset links (e.g. https://yourapp.com or http://localhost:5173)
APP_BASE_URL=http://localhost:5173

PORT=3001

# Debug only: logs full Campaign Monitor API key/secret to the server terminal during "Test connection" (never enable in production)
# CAMPAIGN_MONITOR_DEBUG_LOG=true
